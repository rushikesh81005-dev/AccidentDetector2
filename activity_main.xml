<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛡️ ACCIDENT DETECTOR"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:fontFamily="sans-serif-condensed"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ESP8266/ESP32 Safety System"
            android:textColor="#888888"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingBottom="24dp"/>

        <!-- STATUS CARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/card_normal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvStatusIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="48sp"
                    android:gravity="center"
                    android:paddingBottom="8dp"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SYSTEM NORMAL"
                    android:textColor="@color/status_normal"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvStatusSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monitoring active • Connected to ESP"
                    android:textColor="#aaaaaa"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingTop="6dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CONNECTION STATUS ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <View
                android:id="@+id/viewConnDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle_green"/>

            <TextView
                android:id="@+id/tvConnStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="  Connected to 192.168.4.1"
                android:textColor="#aaaaaa"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvLastUpdate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Updated: just now"
                android:textColor="#666666"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- EMERGENCY CONTACT CARD -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EMERGENCY CONTACT"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_dark"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤"
                        android:textSize="24sp"
                        android:paddingEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvContactName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No contact selected"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvContactNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap below to choose from contacts"
                            android:textColor="#888888"
                            android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btnSelectContact"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📋  SELECT EMERGENCY CONTACT"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_outline"
                    android:letterSpacing="0.05"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ACTIONS SECTION -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MANUAL ACTIONS"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:paddingBottom="8dp"/>

        <!-- Call Button -->
        <Button
            android:id="@+id/btnManualCall"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📞  MANUAL CALL"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/btn_call"
            android:layout_marginBottom="10dp"/>

        <!-- SMS Button -->
        <Button
            android:id="@+id/btnManualSms"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="💬  SEND SMS ALERT"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/btn_sms"
            android:layout_marginBottom="24dp"/>

        <!-- LOCATION INFO -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_dark"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍"
                    android:textSize="20sp"
                    android:paddingEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPS Location"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fetching location..."
                        android:textColor="#888888"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Polling ESP every 2 seconds • v1.0"
            android:textColor="#444444"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingBottom="16dp"/>

    </LinearLayout>
</ScrollView>
